# Required
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/skillsboard
BETTER_AUTH_SECRET=replace-with-a-secret-from-openssl-rand-base64-32
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_your-posthog-project-token
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com


# Recommended for local auth callbacks
BETTER_AUTH_URL=http://localhost:3000

# Optional: invitation email delivery
RESEND_API_KEY=
EMAIL_FROM=Skills Board <onboarding@example.com>

# Optional: increases GitHub API rate limits
GITHUB_TOKEN=

# Optional: injected automatically by Vercel for skills.sh discovery
VERCEL_OIDC_TOKEN=
