# Required
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/skillsboard
BETTER_AUTH_SECRET=replace-with-a-secret-from-openssl-rand-base64-32
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_your-posthog-project-token
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Server/local-only read fallback for `pnpm gtm:pulse:data` when the
# authenticated PostHog connector is unavailable.
# The Personal API Key needs only Query Read permission. Never expose these as NEXT_PUBLIC_*.
# The project token above is for event ingestion and cannot query PostHog.
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_API_HOST=https://eu.posthog.com
POSTHOG_DEPLOYMENT_ENVIRONMENT=production


# Recommended for local auth callbacks
BETTER_AUTH_URL=http://localhost:3000

# Required outside development for email OTP (also used for invitation emails).
# In development, OTP emails are skipped and any 6-digit code works — these can stay empty.
# EMAIL_FROM must use a domain verified in your Resend account.
RESEND_API_KEY=
EMAIL_FROM=Skills Board <login@your-verified-domain.com>

# Optional: increases GitHub API rate limits
GITHUB_TOKEN=

# Optional: injected automatically by Vercel for skills.sh discovery
VERCEL_OIDC_TOKEN=
